{
  "title": "AgroConnect Ghana — Application Dashboard",
  "uid": "agroconnect-app",
  "tags": ["agroconnect", "production"],
  "timezone": "Africa/Accra",
  "refresh": "30s",
  "schemaVersion": 38,
  "panels": [
    {
      "id": 1, "type": "stat", "title": "Backend Uptime",
      "gridPos": {"h": 4, "w": 4, "x": 0, "y": 0},
      "targets": [{"expr": "up{job=\"agroconnect-backend\"}", "legendFormat": "Backend"}],
      "fieldConfig": {
        "defaults": {
          "mappings": [{"options": {"0": {"text": "DOWN"}, "1": {"text": "UP"}}, "type": "value"}],
          "thresholds": {"steps": [{"color": "red", "value": 0}, {"color": "green", "value": 1}]}
        }
      }
    },
    {
      "id": 2, "type": "stat", "title": "HTTP Request Rate (req/s)",
      "gridPos": {"h": 4, "w": 4, "x": 4, "y": 0},
      "targets": [{"expr": "sum(rate(http_requests_total{namespace=\"agroconnect\"}[5m]))", "legendFormat": "Req/s"}]
    },
    {
      "id": 3, "type": "stat", "title": "Error Rate (%)",
      "gridPos": {"h": 4, "w": 4, "x": 8, "y": 0},
      "targets": [{"expr": "sum(rate(http_requests_total{namespace=\"agroconnect\",status=~\"5..\"}[5m])) / sum(rate(http_requests_total{namespace=\"agroconnect\"}[5m])) * 100", "legendFormat": "Error %"}],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "thresholds": {"steps": [{"color": "green", "value": 0}, {"color": "yellow", "value": 1}, {"color": "red", "value": 5}]}
        }
      }
    },
    {
      "id": 4, "type": "stat", "title": "P99 Latency (ms)",
      "gridPos": {"h": 4, "w": 4, "x": 12, "y": 0},
      "targets": [{"expr": "histogram_quantile(0.99, sum(rate(http_request_duration_ms_bucket{namespace=\"agroconnect\"}[5m])) by (le)) * 1000", "legendFormat": "P99"}],
      "fieldConfig": {"defaults": {"unit": "ms"}}
    },
    {
      "id": 5, "type": "stat", "title": "Active Pods",
      "gridPos": {"h": 4, "w": 4, "x": 16, "y": 0},
      "targets": [{"expr": "count(kube_pod_status_phase{namespace=\"agroconnect\",phase=\"Running\"})", "legendFormat": "Running Pods"}]
    },
    {
      "id": 6, "type": "stat", "title": "DB Connections",
      "gridPos": {"h": 4, "w": 4, "x": 20, "y": 0},
      "targets": [{"expr": "pg_stat_activity_count{namespace=\"agroconnect\"}", "legendFormat": "Connections"}]
    },
    {
      "id": 10, "type": "timeseries", "title": "HTTP Request Rate by Endpoint",
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 4},
      "targets": [
        {"expr": "sum by(path) (rate(http_requests_total{namespace=\"agroconnect\"}[5m]))", "legendFormat": "{{path}}"}
      ],
      "fieldConfig": {"defaults": {"unit": "reqps"}}
    },
    {
      "id": 11, "type": "timeseries", "title": "Response Time Percentiles",
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 4},
      "targets": [
        {"expr": "histogram_quantile(0.50, sum(rate(http_request_duration_ms_bucket{namespace=\"agroconnect\"}[5m])) by (le))", "legendFormat": "P50"},
        {"expr": "histogram_quantile(0.95, sum(rate(http_request_duration_ms_bucket{namespace=\"agroconnect\"}[5m])) by (le))", "legendFormat": "P95"},
        {"expr": "histogram_quantile(0.99, sum(rate(http_request_duration_ms_bucket{namespace=\"agroconnect\"}[5m])) by (le))", "legendFormat": "P99"}
      ],
      "fieldConfig": {"defaults": {"unit": "ms"}}
    },
    {
      "id": 20, "type": "timeseries", "title": "Pod CPU Usage",
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 12},
      "targets": [
        {"expr": "sum by(pod) (rate(container_cpu_usage_seconds_total{namespace=\"agroconnect\",container!=\"\"}[5m]))", "legendFormat": "{{pod}}"}
      ],
      "fieldConfig": {"defaults": {"unit": "percentunit"}}
    },
    {
      "id": 21, "type": "timeseries", "title": "Pod Memory Usage",
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 12},
      "targets": [
        {"expr": "sum by(pod) (container_memory_working_set_bytes{namespace=\"agroconnect\",container!=\"\"})", "legendFormat": "{{pod}}"}
      ],
      "fieldConfig": {"defaults": {"unit": "bytes"}}
    },
    {
      "id": 30, "type": "timeseries", "title": "Karpenter Node Count",
      "gridPos": {"h": 6, "w": 8, "x": 0, "y": 20},
      "targets": [
        {"expr": "count(kube_node_info) by (node)", "legendFormat": "Nodes"}
      ]
    },
    {
      "id": 31, "type": "timeseries", "title": "Spot vs On-Demand Nodes",
      "gridPos": {"h": 6, "w": 8, "x": 8, "y": 20},
      "targets": [
        {"expr": "count by(label_karpenter_sh_capacity_type) (kube_node_labels)", "legendFormat": "{{label_karpenter_sh_capacity_type}}"}
      ]
    },
    {
      "id": 32, "type": "timeseries", "title": "RDS Connections",
      "gridPos": {"h": 6, "w": 8, "x": 16, "y": 20},
      "targets": [
        {"expr": "aws_rds_database_connections_average", "legendFormat": "DB Connections"}
      ]
    }
  ],
  "time": {"from": "now-3h", "to": "now"},
  "templating": {
    "list": [
      {
        "name": "namespace", "type": "query", "label": "Namespace",
        "query": "label_values(kube_namespace_labels, namespace)",
        "current": {"value": "agroconnect"}
      }
    ]
  }
}

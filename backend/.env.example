# ── Database ──────────────────────────────────
DATABASE_URL=postgresql://postgres:yourpassword@localhost:5432/agroconnect
PORT=4000
FRONTEND_URL=http://localhost:5173

# ── Hubtel SMS (Ghana) ─────────────────────────
# Get credentials at https://developers.hubtel.com
HUBTEL_CLIENT_ID=your_client_id_here
HUBTEL_CLIENT_SECRET=your_client_secret_here
HUBTEL_SENDER=AgroConnect
# NOTE: Without these, SMS is logged to console only (safe demo mode)
